# ──────────────────────────────────────────────────────────────
#  KORT Backend — Environment Variables
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://kort:kort_secret@localhost:5432/kort_db"

# JWT secrets — CHANGE IN PRODUCTION (min 32 chars recommended)
JWT_ACCESS_SECRET="kort-access-secret-dev-only-change-me"
JWT_REFRESH_SECRET="kort-refresh-secret-dev-only-change-me"

# Token lifetimes
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Server
PORT=8000
HOST="0.0.0.0"

# Frontend origin for CORS
CORS_ORIGIN="http://localhost:5173"

# Dev console password (used by service.routes.ts in non-production only)
CONSOLE_SERVICE_PASSWORD="kortdev1234"

# ── Sprint 10-11: Google Sheets integration (optional, API Key method) ─────────
# 1. Create a Google Cloud project and enable Google Sheets API
# 2. Create an API Key in Google Cloud Console → APIs & Services → Credentials
# 3. Restrict API Key to Google Sheets API only
# 4. Create a Google Sheet and share it
# 5. Run: pnpm install googleapis
# 6. Set the env vars below (already uncommented code in sheets.sync.ts)

GOOGLE_SHEETS_SPREADSHEET_ID="your-spreadsheet-id-here"
GOOGLE_SHEETS_SHEET_NAME="Orders"
GOOGLE_SHEETS_API_KEY="AIza...your-api-key-here"
